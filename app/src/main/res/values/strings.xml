    <!-- Access setup guide -->
    <string name="setup_access_ready_title">Control is ready</string>
    <string name="setup_access_setup_title">Set up charge control</string>
    <string name="setup_access_ready_body">Charge-control access is granted.</string>
    <string name="setup_access_setup_body">Amply needs one durable Android permission to change the charge policy.</string>
    <string name="setup_access_option_shizuku">Option 1 · Shizuku (recommended)</string>
    <string name="setup_access_shizuku_hint">With Shizuku, Amply can confirm the configured policy and run diagnostics — not just write it. Start or install Shizuku and allow Amply; the durable permission is then granted automatically. The button below is a manual fallback if that fails.</string>
    <string name="setup_access_grant_shizuku">Grant permission with Shizuku</string>
    <string name="setup_access_granting_shizuku">Granting…</string>
    <string name="setup_access_allow_shizuku">Allow Amply in Shizuku</string>
    <string name="setup_access_open_shizuku">Open Shizuku</string>
    <string name="setup_access_option_computer">Option 2 · Computer</string>
    <string name="setup_access_webusb_hint">Easiest — no ADB install needed. On the computer your phone is plugged into, open this link in Chrome or Edge to grant control over USB. Shizuku is still needed for diagnostics and reliable readback.</string>
    <string name="setup_access_copy_webusb">Copy web helper link</string>
    <string name="setup_access_adb_hint">Or, if you already have ADB set up on that computer, run:</string>
    <string name="setup_access_copy_adb">Copy ADB command</string>
    <string name="setup_access_adb_refresh_note">Amply detects the permission automatically once it runs — or tap Refresh in the top bar.</string>

