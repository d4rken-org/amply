    <string name="setup_unsupported_title">This device isn\'t supported yet</string>
    <string name="setup_unsupported_body">Amply works by switching your phone\'s built-in battery-protection setting. It hasn\'t been mapped for %1$s devices yet — you can help me add it.</string>
    <string name="setup_unsupported_shares_note">Shares your device\'s model and build details, Android version, battery state, and Amply\'s version and compatibility check. No personal identifiers.</string>
    <string name="setup_unsupported_request_action">Request support on GitHub</string>
    <string name="setup_unsupported_help_action">More help &amp; contact</string>
    <string name="setup_unsupported_dialog_title">Send device details?</string>
    <string name="setup_unsupported_dialog_body">This opens a public GitHub page with the details below filled in. They are sent to GitHub as soon as the page opens; nothing is posted until you submit the issue.</string>
