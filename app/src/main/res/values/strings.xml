    <string name="setup_unsupported_email_note">Prefer email? I\'ll attach the same device details.</string>
    <string name="setup_unsupported_email_action">Contact support by email</string>
    <string name="setup_unsupported_email_body">Hi! I\'d love for Amply to support charge control on my device. I\'ve attached the details Amply collected — hopefully they help you add support. Thanks!</string>
